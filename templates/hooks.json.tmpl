{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov prime --agent {{AGENT_NAME}} $PROJECT_FLAG"
					},
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov mail check --inject --agent {{AGENT_NAME}} $PROJECT_FLAG"
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov mail check --inject --agent {{AGENT_NAME}} $PROJECT_FLAG"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov log tool-start --agent {{AGENT_NAME}} $PROJECT_FLAG --stdin"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "read -r INPUT; CMD=$(echo \"$INPUT\" | sed 's/.*\"command\": *\"\\([^\"]*\\)\".*/\\1/'); if echo \"$CMD\" | grep -qE '\\bgit\\s+push\\b'; then echo '{\"decision\":\"block\",\"reason\":\"git push is blocked — use ov merge to integrate changes, push manually when ready\"}'; exit 0; fi;"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov log tool-end --agent {{AGENT_NAME}} $PROJECT_FLAG --stdin"
					},
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov mail check --inject --agent {{AGENT_NAME}} $PROJECT_FLAG --debounce 500"
					}
				]
			},
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov mail check --inject --agent {{AGENT_NAME}} $PROJECT_FLAG --debounce 30000"
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; read -r INPUT; if echo \"$INPUT\" | grep -qE '\\bgit\\s+commit\\b'; then ml diff HEAD~1 >/dev/null 2>&1 || true; fi; exit 0;"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov log session-end --agent {{AGENT_NAME}} $PROJECT_FLAG --stdin"
					},
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; ml learn"
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "[ -z \"$OVERSTORY_AGENT_NAME\" ] && exit 0; PROJECT_FLAG=\"\"; [ -n \"$OVERSTORY_PROJECT_ID\" ] && PROJECT_FLAG=\"--project $OVERSTORY_PROJECT_ID\"; ov prime --agent {{AGENT_NAME}} --compact $PROJECT_FLAG"
					}
				]
			}
		]
	}
}
